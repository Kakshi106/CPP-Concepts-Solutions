#include <bits/stdc++.h>
using namespace std;
vector <int> bysign(vector <int> &arr){
    int positiveIndex = 0;
    int negativeIndex = 1;
    int n = arr.size();
    vector <int> newarr(3,0);
    for(int i = 0 ; i<n; i++){
        if(arr[i] > 0){
            newarr[positiveIndex] = arr[i];
            positiveIndex += 2;
        }
        else{
            newarr[negativeIndex] = arr[i];
            negativeIndex +=2;
        }
    }
    return newarr;
}