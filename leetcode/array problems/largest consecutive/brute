#include <bits/stdc++.h>
using namespace std;
bool linearSearch(vector <int> &arr , int x){
    for(int i = 0 ; i < arr.size() ; i++){
        if(arr[i] == x)
        return true;
    }
    return false;
}


int largest_consecutive(vector <int> &arr){
    if (arr.empty()){
        return 0;
    }
    int largest = 1;
    
    for(int i = 0 ; i < arr.size() ; i++){
        int x = arr[i];
        int count = 1;
        
        while (linearSearch(arr , x + 1) == true)
        {
            x = x+1;
            count++;
        }
        if (count > largest){
            largest = count ;
        }    
    }
    return largest;
    
}