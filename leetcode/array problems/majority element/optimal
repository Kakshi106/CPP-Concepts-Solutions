#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int majorityElement(vector<int>& arr) {
    int count1 = 0;
    int el;
    for(int i = 0; i< arr.size() ; i++){
        if(count1 == 0){
            el == arr[i];
            count1 = 1;
        }
        if(arr[i] == el){
            count1++;
        }
        if(arr[i] != el){
            count1--;
        }
    }
    int count2;
    for(int i = 0; i< arr.size() ; i++){
        if(arr[i] == el) count2++;

        if(count2 > (arr.size()/2))
        return el;
    }
    return -1;
}
}; 