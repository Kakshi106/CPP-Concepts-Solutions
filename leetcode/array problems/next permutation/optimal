#include <bits/stdc++.h>
using namespace std;
vector <int> next_permutation(vector <int> &arr){
    int n = arr.size();
    int ind = -1;
    for(int i = n-2; i >= 0; i--){
        if(arr[i] < arr[i=1]){
            ind = i;
            break;
        }
    }                                                  //time complexity O(3N)
    if(ind == -1){                                     //space complexity Best: O(N) . Worst: O(1)
        reverse(arr.begin(), arr.end());
        return;
    }
    for(int i = n-1; i> 0; i++){
        if(arr[ind] < arr[i]){
            swap(arr[i], arr[ind]);
            break;
        }
    }
    reverse(arr.begin() + ind + 1 , arr.end());

}