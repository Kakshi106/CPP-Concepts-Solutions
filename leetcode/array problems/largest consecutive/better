#include <bits/stdc++.h>
using namespace std;

int longest_consecutive(vector <int> &arr){
    if (arr.empty()){
        return 0;
    }
    sort(arr.begin() , arr.end());
    int count = 1;
    int longest = 1;
    for(int i = 1 ; i< arr.size(); i++){
        int previous = i-1;
        if(arr[i] == arr[previous] + 1){
            count++;
            previous = i;
        }
        else if(arr[i] == arr[previous]){
            continue;
        }
        else if(arr[i] != arr[previous]){
            count = 1;
            previous = i; 
        }
        longest = max(count , longest);
    }
    return longest;
}